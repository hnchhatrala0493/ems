# Public URL of the separately deployed API. Include the /api/v1 prefix.
VITE_API_URL=https://your-api.example.com/api/v1

# Public origin of the persistent Socket.IO backend (no /api/v1 suffix).
VITE_SOCKET_URL=https://your-api.example.com

# Canonical public frontend URL, used for SEO metadata.
VITE_SITE_URL=https://your-project.vercel.app
